<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema base de UltiMusic: siempre oscuro (negro) con acento amarillo. -->
    <style name="Base.Theme.UltiMusic" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/um_yellow</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/um_yellow</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/um_background</item>
        <item name="colorSurface">@color/um_surface</item>
        <item name="colorSurfaceVariant">@color/um_surface_variant</item>
        <item name="colorOnBackground">@color/um_on_background</item>
        <item name="colorOnSurface">@color/um_on_background</item>
        <item name="android:statusBarColor">@color/um_background</item>
        <item name="android:navigationBarColor">@color/um_background</item>
    </style>

    <style name="Theme.UltiMusic" parent="Base.Theme.UltiMusic" />

    <!-- Tema del diálogo del iPod: pantalla completa, fondo transparente y animación de deslizamiento. -->
    <style name="Theme.UltiMusic.IPodDialog" parent="Theme.UltiMusic">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@style/Animation.UltiMusic.SlideUp</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/um_background</item>
    </style>
</resources>
